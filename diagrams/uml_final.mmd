classDiagram
    %% PawPal+ Pet Care Scheduling System (Phase 2 - Final Implementation)
    %% Complete class diagram with all attributes, methods, and relationships
    %% Validated against pawpal_system.py - 100% coverage

    %% ============================================================================
    %% ENUMS
    %% ============================================================================
    class Priority {
        <<enumeration>>
        LOW
        MEDIUM
        HIGH
    }

    class Frequency {
        <<enumeration>>
        ONCE
        DAILY
        WEEKLY
        MONTHLY
    }

    %% ============================================================================
    %% CORE DOMAIN CLASSES
    %% ============================================================================

    class Task {
        +String title
        +Int duration_minutes
        +Priority priority
        +String description
        +Optional[Time] scheduled_time
        +Frequency frequency
        +Bool is_completed
        --
        +get_priority_value() Int
        +get_duration() Int
        +mark_completed() None
        +mark_incomplete() None
        +__str__() String
    }

    class Pet {
        +String name
        +String species
        +Int age
        +List[String] special_needs
        +List[Task] tasks
        --
        +__post_init__() None
        +has_special_needs() Bool
        +get_care_requirements() List[Task]
        +add_task(Task) None
        +remove_task(Task) None
        +get_incomplete_tasks() List[Task]
        +__str__() String
    }

    class Owner {
        +String name
        +Time available_start_time
        +Time available_end_time
        +List[Pet] pets
        --
        +add_pet(Pet) None
        +remove_pet(Pet) None
        +get_available_hours() Float
        +get_availability_window() Tuple
        +get_all_tasks() List[Task]
        +get_incomplete_tasks() List[Task]
        +get_tasks_for_pet(Pet) List[Task]
        +__str__() String
    }

    %% ============================================================================
    %% SCHEDULER (The "Brain" of the System)
    %% ============================================================================

    class Scheduler {
        %% Core Scheduling (3 methods)
        +schedule_tasks(Owner, Pet, List[Task], DateTime) List[Task]
        +get_daily_schedule(Owner, DateTime) Dict
        +get_task_summary(Owner) Dict
        %% Sorting (Multi-criteria) (4 methods)
        +prioritize_tasks(List[Task]) List[Task]
        +sort_by_time(List[Task]) List[Task]
        +sort_by_duration(List[Task]) List[Task]
        +sort_by_priority_then_time(List[Task]) List[Task]
        %% Filtering (3 methods)
        +filter_tasks(List[Task], Pet?, String, Priority?) List[Task]
        +filter_by_pet_name(Owner, String, String) List[Task]
        +filter_by_status(List[Task], String) List[Task]
        %% Conflict Detection (3-tier severity) (2 methods)
        +detect_conflicts(List[Task], Dict?) List[Tuple]
        +detect_conflicts_with_warnings(Owner, DateTime?) List[Dict]
        %% Recurring Task Management (2 methods)
        +expand_recurring_tasks(List[Task], Int) List[Task]
        +complete_recurring_task(Pet, Task) Task?
    }

    %% ============================================================================
    %% RELATIONSHIPS
    %% ============================================================================

    %% Domain Model Relationships
    Owner "1" --> "*" Pet : owns
    Pet "1" --> "*" Task : has

    %% Type Dependencies
    Task --> Priority : uses
    Task --> Frequency : uses

    %% Scheduler Relationships (orchestrator pattern)
    Scheduler --> Owner : uses/schedules
    Scheduler --> Pet : filters/operates on
    Scheduler --> Task : processes/expands
    Scheduler --> Priority : reads for sorting
    Scheduler --> Frequency : reads for recurrence

    %% ============================================================================
    %% DESIGN NOTES
    %% ============================================================================
    note "🐾 PawPal+ Architecture:\n\nScheduler acts as the 'orchestrator' of the system.\nIt coordinates Owner, Pet, and Task objects\nfor intelligent scheduling and conflict detection."
    note "Priority & Frequency enums enable\ntype-safe scheduling decisions.\n\nPhase 2 Added:\n• Scheduler class (14 methods)\n• Task state management\n• Conflict detection\n• Recurring task support\n• Multi-criteria sorting & filtering"
